<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    MASTER TEST SUITE
    Runs all tags: @ui  @api  @db
    Parallel: methods — each @Test method runs in its own thread
    Thread count: 4 (override with -DthreadCount=N)
-->
<suite name="Enterprise QA — Full Suite"
       verbose="1"
       parallel="methods"
       thread-count="4"
       data-provider-thread-count="4">

    <!-- Global listeners wired here so every test gets retry + Allure -->
    <listeners>
        <listener class-name="com.framework.utils.RetryListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- ── UI Tests ───────────────────────────────────────────────────── -->
    <test name="UI — Login" preserve-order="true">
        <parameter name="browser" value="${browser:-chrome}"/>
        <parameter name="engine"  value="${engine:-selenium}"/>
        <parameter name="cucumber.filter.tags" value="@ui and @login"/>
        <classes>
            <class name="com.framework.runners.LoginTestRunner"/>
        </classes>
    </test>

    <test name="UI — Credit Card Payments" preserve-order="true">
        <parameter name="browser" value="${browser:-chrome}"/>
        <parameter name="engine"  value="${engine:-selenium}"/>
        <parameter name="cucumber.filter.tags" value="@ui and @payments"/>
        <classes>
            <class name="com.framework.runners.CreditCardTestRunner"/>
        </classes>
    </test>

    <test name="UI — Risk Rating" preserve-order="true">
        <parameter name="browser" value="${browser:-chrome}"/>
        <parameter name="engine"  value="${engine:-selenium}"/>
        <parameter name="cucumber.filter.tags" value="@ui and @risk"/>
        <classes>
            <class name="com.framework.runners.RiskRatingTestRunner"/>
        </classes>
    </test>

    <test name="UI — File Transfer" preserve-order="true">
        <parameter name="browser" value="${browser:-chrome}"/>
        <parameter name="engine"  value="${engine:-selenium}"/>
        <parameter name="cucumber.filter.tags" value="@ui and @filetransfer"/>
        <classes>
            <class name="com.framework.runners.FileTransferTestRunner"/>
        </classes>
    </test>

    <test name="UI — Broken Links and Images" preserve-order="true">
        <parameter name="browser" value="${browser:-chrome}"/>
        <parameter name="engine"  value="${engine:-selenium}"/>
        <parameter name="cucumber.filter.tags" value="@ui and @brokenlinks"/>
        <classes>
            <class name="com.framework.runners.BrokenLinksTestRunner"/>
        </classes>
    </test>

    <!-- ── API Tests ──────────────────────────────────────────────────── -->
    <test name="API — All Endpoints" preserve-order="true">
        <parameter name="cucumber.filter.tags" value="@api"/>
        <classes>
            <class name="com.framework.runners.ApiTestRunner"/>
        </classes>
    </test>

    <!-- ── DB / ETL Tests ─────────────────────────────────────────────── -->
    <test name="DB — ETL Validation" preserve-order="true">
        <parameter name="cucumber.filter.tags" value="@db"/>
        <classes>
            <class name="com.framework.runners.DbTestRunner"/>
        </classes>
    </test>

</suite>